component C {
  use Base;

  let char = 'c';

  <section>
    String.uppercase_ascii("abc횪채철체횩"): {String.uppercase_ascii("abc횪채철체횩")}
    String.lowercase_ascii("ABC횁횆횜횥횩"): {String.lowercase_ascii("ABC횁횆횜횥횩")}
    String.capitalize_ascii("abc"): {String.capitalize_ascii("abc")}
    String.capitalize_ascii("채철체"): {String.capitalize_ascii("채철체")}

    char: {char}
    char + 1: {char + 1}

    {' ' + 1}
    {'\ ' + 1}
    {'\\'}
    {'\n'}
    {'\''}
    {'\t'}
    {'\xA9'}
    {'\o777'}
    {'\033' + 128512}
  </section>
}
